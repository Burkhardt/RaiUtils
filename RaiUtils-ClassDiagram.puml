@startuml RaiUtils-Class-Diagram
' Release: 3.7.6

title RaiUtils Class Diagram

skinparam backgroundColor white
skinparam shadowing false
skinparam DiagramFontName "Casual"
skinparam DiagramFontSize 36
skinparam ClassFontName "Casual"
skinparam ClassFontSize 36
skinparam ClassAttributeIconSize 10
skinparam ClassAttributeFontName Casual
skinparam ClassAttributeFontColor #053583
skinparam ClassAttributeFontWeight normal
skinparam ClassAttributeFontSize 12
skinparam ClassMethodFontName "Casual"
skinparam ClassMethodFontSize 12
skinparam ClassMethodFontWeight 500
skinparam ClassAttributeFontStyle normal
skinparam ClassBorderColor #0f766e
skinparam ClassBackgroundColor #ccfbf1
skinparam ClassFontColor #111827
skinparam EnumBorderColor #b45309
skinparam EnumBackgroundColor #fef3c7
skinparam EnumFontColor #7c2d12
skinparam NoteBackgroundColor #fff7d6
skinparam NoteBorderColor #d4b106
skinparam ArrowColor #9b2c2c
skinparam ArrowFontColor #374151
skinparam ArrowFontName "Casual"

show fields
show methods

package "RaiUtils" {
	class "<size:18>Email</size>" as Email {
		-address : string
		+Valid : bool
		+Invalid : bool
		+ToString() : string
	}

	class "<size:18>ParameterDictionary</size>" as ParameterDictionary {
		+ParameterDictionary(paramArray : NameValueCollection)
	}

	class "<size:18>SearchExpression</size>" as SearchExpression {
		-conditions : List<string>
		+ConditionsAsString : string
		+IsMatch(obj : object) : bool
		+SearchExpression(pattern : string)
	}

	class "<size:18>JsonConversionExtensions</size> Ⓢ" as JsonConversionExtensions {
		+{static} ToDictionary(json : JObject) : IDictionary<string, object>
		+{static} ToArray(array : JArray) : object[]
	}

	class "<size:18>RandomExtensions</size> Ⓢ" as RandomExtensions {
		+{static} Random<T>(list : IEnumerable<T>, rand : Random) : T
		+{static} Shuffle<T>(source : IEnumerable<T>) : IEnumerable<T>
		+{static} Shuffle<T>(source : IEnumerable<T>, rand : Random) : IEnumerable<T>
		+{static} Shuffle<T>(list : IList<T>) : void
		+{static} Shuffle<T>(list : IList<T>, rand : Random) : void
		+{static} TakeAny<T>(source : IEnumerable<T>, take : int) : IEnumerable<T>
	}
}

class "StringDictionary" as StringDictionary <<external System.Collections.Specialized>>
class "NameValueCollection" as NameValueCollection <<external System.Collections.Specialized>>
class "JObject" as JObject <<external Newtonsoft>>
class "JArray" as JArray <<external Newtonsoft>>

ParameterDictionary --|> StringDictionary
ParameterDictionary ..> NameValueCollection : ctor input
JsonConversionExtensions ..> JObject : extension on
JsonConversionExtensions ..> JArray : extension on

class "Legend<size:10>ⓈⒶⓅ</size>" as LegendSample {
	+{static} staticMethod() : void
	-{static} staticProperty : string
	==
	~<i>Note on class markers :</i>
	<size:10>Ⓢ</size>tatic
	<size:10>Ⓐ</size>bstract
	Ⓟartial
	--
	- privateField : string
	+ publicField : string
	# protectedField : string
	~ internalField : string
	--
	- privateMethod() : void
	+ publicMethod() : void
	# protectedMethod() : void
	~ internalMethod() : void
}

note right of SearchExpression
	Pattern features:
	- wildcard matching
	- `+` means AND within a token
	- `field=value` scopes matching
end note

note bottom
	OsLib relationship:
	there is no direct inheritance
	or package-level dependency on
	OsLib in the current RaiUtils
	source files.
end note

@enduml
